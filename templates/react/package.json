{
  "name": "{{APP_NAME}}-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "yarn install && node --max-old-space-size=4096 node_modules/vite/bin/vite.js build",
    "serve": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "biome check --write .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.56.2",
    "dayjs": "^1.11.7",
    "frappe-ui": "^0.1.269",
    "lucide-react": "^0.447.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "socket.io-client": "^4.7.2",
    "tailwindcss": "^3.4.15",
    "zod": "^3.21.4",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "^24.5.2",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^25.0.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vitest": "^2.1.8"
  }
}
