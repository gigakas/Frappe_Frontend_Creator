    "@vueuse/core": "^10.0.2",
    "dayjs": "^1.11.7",
    "frappe-ui": "^0.1.269",
    "lodash": "^4.17.21",
    "pinia": "^2.0.33",
    "socket.io-client": "^4.7.2",
    "tailwindcss": "^3.4.15",
    "unplugin-icons": "^23.0.0",
    "unplugin-vue-components": "^0.25.2",
    "vue": "^3.5.21",
    "vue-router": "^4.5.1",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
