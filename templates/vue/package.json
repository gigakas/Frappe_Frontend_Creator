{
  "name": "{{APP_NAME}}-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "yarn install && node --max-old-space-size=4096 node_modules/vite/bin/vite.js build",
    "serve": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "biome check --write .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.22",
    "@iconify-json/lucide": "^1.1.99",
